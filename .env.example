# ─── LLM Enrichment ───────────────────────────────────────
# Provider: ollama | gemini | openai
AURA_LLM_PROVIDER=ollama
AURA_OLLAMA_URL=http://localhost:11434
AURA_GEMINI_API_KEY=
AURA_OPENAI_API_KEY=

# LLM model name (used for Ollama model or API model selection)
AURA_LLM_MODEL=llama3

# ─── Embeddings ───────────────────────────────────────────
AURA_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ─── Elasticsearch ────────────────────────────────────────
AURA_ES_URL=http://localhost:9200
AURA_ES_INDEX=aura-market-data

# ─── API Bridge ───────────────────────────────────────────
AURA_API_HOST=0.0.0.0
AURA_API_PORT=8000

# ─── Frontend (existing chat_app keys) ───────────────────
VITE_GROQ_API_KEY=
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_TTS_API_URL=
VITE_API_URL=http://localhost:8000
